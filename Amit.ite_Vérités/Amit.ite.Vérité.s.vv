  # Calcul du Mental Physique (Sociabilité des Mentaux)
  def coef_kef(securite, vigilance):
      # On cherche la sécurité dans la sécurité, avec une touche d'alerte
      return (securite * vigilance) + (1 - vigilance)

  print("Système ViA stabilisé sur le Coef Kef.")
