        tk.Label(self.dash_ctrl, text="SAR: ACTIVE", bg="#111", fg="lime").pack(side="right", padx=20)

        # --- 3. LE CLAVIER SWITCHABLE (ZONE BASSE) ---
        self.input_zone = tk.Frame(self.root, bg="#020202")
        self.input_zone.place(relx=0, rely=0.72, relwidth=1, relheight=0.28)
        
        self.generate_alphanumero_keyboard()

    def generate_alphanumero_keyboard(self):
        """Génère le clavier basé sur tes dessins GitHub"""
        self.keys_frame = tk.Frame(self.input_zone, bg="#020202")
        self.keys_frame.pack(expand=True)
        
        # Mappage simplifié des traits/points remasterisés
        alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789(10)"
        r, c = 0, 0
        for char in alphabet:
            btn = tk.Button(self.keys_frame, text=char, width=4, height=1,
                            font=("Courier", 12, "bold"),
                            bg="#1a1a1a", fg="#00ccff",
                            command=lambda x=char: self.input_vector(x))
            btn.grid(row=r, column=c, padx=2, pady=2)
            c += 1
            if c > 12: c = 0; r += 1

    def switch_mode(self):
        """Alterne entre le clavier géométrique et le panel de pilotage"""
        if self.keyboard_visible:
            self.keys_frame.pack_forget()
            # On remplace par les commandes de pilotage GoleMotor
            self.cmd_panel = tk.Frame(self.input_zone, bg="#020202")
            self.cmd_panel.pack(expand=True)
            tk.Button(self.cmd_panel, text="INJECTION 1 MW", bg="red", fg="white", font=("bold", 20)).pack()
            print("[SWITCH] Mode Commande Activé.")
        else:
            self.cmd_panel.pack_forget()
            self.keys_frame.pack(expand=True)
            print("[SWITCH] Mode Alphanuméro Activé.")
        
        self.keyboard_visible = not self.keyboard_visible

    def input_vector(self, char):
        # Logique du Revitaliseur intégrée à chaque touche
        self.display_log.insert(tk.END, f"\nVecteur {char} détecté. Nettoyage SAR...")
        self.display_log.see(tk.END)

if __name__ == "__main__":
    root = tk.Tk()
    app = ViADashPanel(root)
    root.mainloop()
(vector.end)


