(py)
  def calcul_libarchie(unite_a, unite_b):
      # Dans la Libarchie, l'union dépasse la somme
      potentiel_creatif = (unite_a * unite_b) ** 10 # Expansion exponentielle
      if potentiel_creatif > 1000000:
          return "ÉTAT : INFINI (Omniprésence activée)"
      return potentiel_creatif
