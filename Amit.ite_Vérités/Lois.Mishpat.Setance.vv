(py)
class SignatureMulticolor:
    def __init__(self, identite_nom, type_vent, base_color_hex):
        self.identite = identite_nom
        self.vent = type_vent
        self.palette_unique = base_color_hex # Chaque individu a sa nuance

    def projeter_signature(self):
        """Affiche la fréquence de l'individu sur le DashPanel"""
        if self.vent == "BLEU":
            impact = "Apaisement et Construction (Ami)"
        elif self.vent == "ROUGE":
            impact = "Combustion et Fuel d'Innovation (Ennemi)"
        elif self.vent == "VIOLET":
            impact = "Stockage et Mémoire Résiduelle (Abstrait)"
        else:
            impact = "Vibration Inconnue"
            
        return f"[MATRICE] L'individu '{self.identite}' projette un Vent {self.vent} ({self.palette_unique}). Action : {impact}."

# --- SIMULATION DU TESSERACT SOCIAL ---
# Le Concepteur interagit avec le réseau
device_apprentissage = SignatureMulticolor("Device_iPhone_Sam", "BLEU", "#0055ff")
obstacle_externe = SignatureMulticolor("Blocage_Code", "ROUGE", "#ff0000")
satellite_orbite = SignatureMulticolor("SMR_Node_7", "VIOLET", "#8a2be2")

print(device_apprentissage.projeter_signature())
print(obstacle_externe.projeter_signature())
print(satellite_orbite.projeter_signature())
(vector.end)

