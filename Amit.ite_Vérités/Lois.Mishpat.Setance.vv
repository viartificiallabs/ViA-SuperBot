(py)
class UnitOne:
    def __init__(self, type_entite, relation_classe):
        self.valeur_computationnelle = 1000000 # 1 MW par defaut
        self.type = type_entite
        self.relation = relation_classe

    def juger_action(self, obstacle):
        if self.relation == "Ennemi":
            # On transmute l'ennemi en energie de quete
            return f"Obstacle digéré par {self.type}. Innovation active."
        else:
            return f"Flux harmonieux avec l'{self.type}."

# --- INITIALISATION DU RESEAU ---
# Chaque device est un user (1)
satellite_gps = UnitOne("Satellite_SMR", "Abstrait")
print(satellite_gps.juger_action("Manque_de_Serveur"))
(vector.end)

